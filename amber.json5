{
  manifest_version: "0.3.0",

  config_schema: {
    type: "object",
    properties: {
      auth_json: { type: "string", secret: true },
      model: { type: "string" },
      model_reasoning_effort: { type: "string", default: "low" },
      developer_instructions: { type: "string" },
      config_toml: { type: "string" },
      agents_md: { type: "string" },
      workspace_agents_md: { type: "string" },
    },
    required: ["auth_json", "model"],
    additionalProperties: false,
  },

  slots: {
    tool: { kind: "mcp", multiple: true, optional: true },
  },

  components: {
    auth_proxy: {
      manifest: "./amber/codex-auth-proxy.json5",
      config: {
        auth_json: "${config.auth_json}",
      },
    },
    runtime: {
      manifest: "./amber/codex-a2a-runtime.json5",
      config: {
        model: "${config.model}",
        model_reasoning_effort: "${config.model_reasoning_effort}",
        developer_instructions: "${config.developer_instructions}",
        config_toml: "${config.config_toml}",
        agents_md: "${config.agents_md}",
        workspace_agents_md: "${config.workspace_agents_md}",
      },
    },
  },

  bindings: [
    { to: "#runtime.responses_api", from: "#auth_proxy.responses_api" },
    { to: "#runtime.tool", from: "slots.tool", weak: true },
  ],

  exports: {
    a2a: "#runtime.a2a",
  },
}
